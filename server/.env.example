# ============================================
# Fi Money Notes App — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

# ─── Database (NeonDB PostgreSQL) ────────────
# Get your connection string from https://console.neon.tech
# Format: postgresql://<user>:<password>@<endpoint>.neon.tech/<dbname>?sslmode=require
DATABASE_URL="postgresql://username:password@ep-xxxxx-xxxxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Prisma CLI direct URL used by generate/db push
# Optional: use a separate direct connection for Prisma CLI tasks.
# If omitted, the app falls back to `DATABASE_URL`.
DIRECT_URL="postgresql://username:password@ep-xxxxx-xxxxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Server ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Authentication ─────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ─── CORS ────────────────────────────────────
# Comma-separated allowed browser origins
CORS_ORIGIN="http://localhost:5173,https://fi-notes.vercel.app"
